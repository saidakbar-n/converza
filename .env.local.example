# Copy to .env.local and load when using local Postgres:
#   cp .env.local.example .env.local
#   ./scripts/local-db.sh start
#
# Apps load .env.local AFTER .env and override Supabase URL/key only.
# Cloud Supabase values stay in .env — switch back by removing/renaming .env.local.

# Local PostgREST gateway (same /rest/v1 path as Supabase cloud)
SUPABASE_URL=http://127.0.0.1:54321
# Demo service_role JWT (matches PGRST_JWT_SECRET in docker-compose.local.yml)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Direct Postgres (for psql / migrations only — apps use REST above)
