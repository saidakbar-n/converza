ENV=development

# Hermes Agent — sole LLM runtime (hermes gateway + API server on :8642)
HERMES_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent
API_SERVER_ENABLED=true
API_SERVER_KEY=change-me-local-dev
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ContentCreator media jobs only (KIE video/image APIs)
KIE_API_KEY=your_kie_api_key_here

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

TELEGRAM_BOT_TOKEN=your_sales_bot_token_here
TELEGRAM_BOT_USERNAME=ConverzaSales_bot
TELEGRAM_APP_BOT_TOKEN=your_app_bot_token_here
TELEGRAM_APP_BOT_USERNAME=ConverzaApp_bot

BOT_INTERNAL_URL=http://localhost:8000

ALLOWED_ORIGINS=http://localhost:8001

JWT_SECRET=dev-insecure-change-me-in-production

ADMIN_TELEGRAM_IDS=your_telegram_user_id
