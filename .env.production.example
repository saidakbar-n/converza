# Combined production env for VPS (/etc/converza/.env)
# Copy to the server and fill every value. Never commit real secrets.

ENV=production

# Supabase (cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# LLM APIs
GROQ_API_KEY=your_groq_api_key_here
KIE_API_KEY=your_kie_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=ConverzaSales_bot
TELEGRAM_WEBHOOK_SECRET=generate_a_long_random_secret_here
WEB_APP_URL=https://getconverza.com
# Optional: shared webhook dedup when running multiple bot workers
# REDIS_URL=redis://127.0.0.1:6379/0

# Payments (Click via BotFather)
CLICK_PROVIDER_TOKEN=your_click_provider_token_here
# CLICK_TEST_PROVIDER_TOKEN=   # omit in production unless testing

# Web service
BOT_INTERNAL_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=https://getconverza.com
JWT_SECRET=generate_a_long_random_jwt_secret_here

# Admin Telegram user ids (comma-separated) — can approve access requests at /admin
ADMIN_TELEGRAM_IDS=123456789

# Optional
HITL_ENABLED=false
# TELEGRAM_HITL_BOT_TOKEN=
# DEFAULT_ORG_ID=   # do NOT set in production
