# Combined production env for VPS (/etc/converza/.env)
# Copy to the server and fill every value. Never commit real secrets.

ENV=production

# Supabase (cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Hermes Agent — sole LLM runtime for all Converza agents
HERMES_URL=http://127.0.0.1:8642
HERMES_API_KEY=generate_a_long_random_secret_here
HERMES_MODEL=hermes-agent
# LLM provider for Hermes gateway (auto-detects from keys; Groq preferred if set)
CONVERZA_LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
HERMES_GROQ_MODEL=llama-3.3-70b-versatile

# Option B — Google Gemini (optional fallback)
# GOOGLE_API_KEY=your_google_ai_studio_key_here
# HERMES_GEMINI_MODEL=gemini-2.0-flash

# Option C — Anthropic Claude
# CONVERZA_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# HERMES_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option D — OpenRouter (many models)
# OPENROUTER_API_KEY=your_openrouter_key_here

# Hermes gateway API server (same key as HERMES_API_KEY)
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642
API_SERVER_KEY=generate_a_long_random_secret_here

# Media pipeline (ContentCreator DAG node only — not used for chat/closer)
KIE_API_KEY=your_kie_api_key_here

# Telegram — two bots
# @ConverzaSales_bot — Business DM closer + end-customer Click invoices
TELEGRAM_BOT_TOKEN=your_sales_bot_token_here
TELEGRAM_BOT_USERNAME=ConverzaSales_bot

# @ConverzaApp_bot — website login, onboarding, admin, Converza subscription
TELEGRAM_APP_BOT_TOKEN=your_app_bot_token_here
TELEGRAM_APP_BOT_USERNAME=ConverzaApp_bot

TELEGRAM_WEBHOOK_SECRET=generate_a_long_random_secret_here
WEB_APP_URL=https://getconverza.com

# Converza subscription (Click on @ConverzaApp_bot via BotFather → Payments)
CONVERZA_SUBSCRIPTION_PROVIDER_TOKEN=your_app_bot_click_provider_token
CONVERZA_SUBSCRIPTION_PRICE_UZS=500000
CONVERZA_SUBSCRIPTION_PERIOD_DAYS=30
SUBSCRIPTION_REQUIRED=true

# Web service (host network on VPS)
BOT_INTERNAL_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=https://getconverza.com
JWT_SECRET=generate_a_long_random_jwt_secret_here

# Admin Telegram user ids (comma-separated)
ADMIN_TELEGRAM_IDS=123456789

# Optional
HITL_ENABLED=false

# Payments — per-organization Click token in brand passport (no global token)
